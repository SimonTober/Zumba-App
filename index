    { name: "Bollywood-Arme", desc: "Klassische Bollywood-Armbewegungen mit Achter-Schritt. Fröhlich, ausdrucksstark, viel Energie." },
    { name: "Reggaeton Perreo", desc: "Tiefes Kniebeugen, Hüftkrreisen, Arme nach vorne. Kraftvoll und rhythmisch, kurze Wiederholungen." },
    { name: "Afro-Cuban Step", desc: "Tiefer Stand, Oberkörper bewegt sich wellenförmig mit Seitschritten. Afrikanisch inspiriert, erdverbunden." },
    { name: "Samba mit Armen", desc: "Schneller Samba-Bounce, Arme wechseln zwischen Kopfhöhe und Hüfte. Energie hochhalten!" },
    { name: "Pop-Isolation", desc: "Hüft- und Schulter-Isolationen im modernen Pop-Rhythmus. Jeder Körperteil einzeln bewegen." },
    { name: "Mambo Kick", desc: "Mambo-Schritte mit Beinauswurf auf Takt 3. Knie weich, Oberkörper stabil. Power-Bewegung!" },
    { name: "Hip-Hop Shuffle", desc: "Schritt-Touch seitwärts mit Armswings. Locker und groovy, auf den Takt achten." },
    { name: "Tropical Step", desc: "Leichte Fußarbeit mit Armwellen über den Kopf. Karibisches Feeling, entspannt und rhythmisch." },
    { name: "Bachata mit Drehung", desc: "Bachata-Grundschritt mit Spin nach je 8 Takten. Drehung langsam beginnen, dann flüssiger werden." },
    { name: "Latin Freeze", desc: "Kurze Power-Sequenz gefolgt von einem 'Einfrieren' auf Takt 8. Überraschungsmoment für die Gruppe!" },
    { name: "Zumba-Kombination", desc: "Mix aus Merengue, Salsa und Cumbia in einer 16-Takt-Phrase. Höhepunkt der Stunde – alles zusammen!" },
  ],
  cooldown: [
    { name: "Langsamer Merengue", desc: "Sehr ruhiger Merengue-Schritt, Herzfrequenz senken. Tiefes Atmen, Bewegungen kleiner werden lassen." },
    { name: "Schulter-Stretch", desc: "Einen Arm quer vor die Brust, 20 Sekunden halten, wechseln. Schultermuskel gut dehnen." },
    { name: "Hüftbeuger-Dehnung", desc: "Ausfallschritt, hinteres Knie fast am Boden, Hüfte nach vorne schieben. 25 Sekunden pro Seite." },
    { name: "Seitliche Rumpfdehnung", desc: "Arm über den Kopf zur Seite beugen, Körperseite dehnen. Langsam und kontrolliert atmen." },
    { name: "Waden-Stretch", desc: "Hände an die Wand, ein Bein gestreckt zurück, Ferse drückt zum Boden. 20 Sek. halten." },
    { name: "Oberschenkel-Dehnung", desc: "Im Stand ein Bein anwinkeln, Fuß zur Gesäß ziehen. Balance halten oder Stuhl nutzen. Für 20 Sek." },
    { name: "Katze-Kuh-Bewegung", desc: "Im Stand: Rücken runden und strecken abwechselnd. Wirbelsäule mobilisieren, tief atmen." },
    { name: "Nacken-Rollen", desc: "Kopf langsam von einer Seite zur anderen rollen, nie ganz nach hinten. Nackenmuskulatur lockern." },
    { name: "Große Atemrunde", desc: "Arme beim Einatmen heben, beim Ausatmen senken. Dreimal wiederholen. Gruppe gut einbinden." },
    { name: "Stehende Rumpfrotation", desc: "Hände an die Hüften, Oberkörper langsam von links nach rechts drehen. Wirbelsäule mobilisieren." },
  ]
};

const MUSIC = [
  { phase: "Warm-Up", title: "Vivir Mi Vida", artist: "Marc Anthony", bpm: 95 },
  { phase: "Warm-Up", title: "La Bamba", artist: "Ritchie Valens", bpm: 98 },
  { phase: "Warm-Up", title: "Bamboleo", artist: "Gipsy Kings", bpm: 100 },
  { phase: "Warm-Up", title: "Conga", artist: "Gloria Estefan", bpm: 102 },
  { phase: "Warm-Up", title: "Macarena", artist: "Los del Río", bpm: 104 },
  { phase: "Latin", title: "Despacito", artist: "Luis Fonsi", bpm: 126 },
  { phase: "Latin", title: "Bailando", artist: "Enrique Iglesias", bpm: 130 },
  { phase: "Latin", title: "Hips Don't Lie", artist: "Shakira", bpm: 128 },
  { phase: "Latin", title: "Waka Waka", artist: "Shakira", bpm: 132 },
  { phase: "Latin", title: "Gasolina", artist: "Daddy Yankee", bpm: 129 },
  { phase: "Latin", title: "La Tortura", artist: "Shakira", bpm: 127 },
  { phase: "Party", title: "Con Calma", artist: "Daddy Yankee", bpm: 134 },
  { phase: "Party", title: "Lean On", artist: "Major Lazer", bpm: 136 },
  { phase: "Party", title: "Boom Boom", artist: "RedOne", bpm: 138 },
  { phase: "Party", title: "Danza Kuduro", artist: "Don Omar", bpm: 140 },
  { phase: "Party", title: "Magalenha", artist: "Sérgio Mendes", bpm: 135 },
  { phase: "Party", title: "Soca Dance", artist: "Faye-Ann Lyons", bpm: 142 },
  { phase: "Cool-Down", title: "Quizás, Quizás, Quizás", artist: "Nat King Cole", bpm: 78 },
  { phase: "Cool-Down", title: "Bésame Mucho", artist: "Andrea Bocelli", bpm: 75 },
  { phase: "Cool-Down", title: "La Vie en Rose", artist: "Édith Piaf", bpm: 72 },
  { phase: "Cool-Down", title: "Perhaps Love", artist: "José Carreras", bpm: 74 },
];

const TIPS = [
  "Erinnere die Teilnehmerinnen: Jede macht ihr eigenes Tempo – keine Vergleiche, nur Freude!",
  "Lächeln ist Pflicht! Eine gute Atmosphäre motiviert mehr als die perfekte Technik.",
  "Pausen sind okay. Wer Wasser braucht, holt sich Wasser – kein Durchhalten erzwingen.",
  "Variationen anbieten: Für Anfängerinnen kleinere Schritte, für Fortgeschrittene mehr Hüfteinsatz.",
  "Augenkontakt mit der Gruppe halten – das schafft Verbindung und Motivation.",
  "Nach der Stunde kurz nachfragen: Was hat am meisten Spaß gemacht? Feedback ist Gold!",
  "Musik etwas lauter in der Hauptphase, im Cool-Down deutlich leiser – das hilft dem Körper runterzukommen.",
  "Komplimente verteilen! Einzelne Teilnehmerinnen gezielt loben – das bleibt in Erinnerung.",
];

function pick(arr, n) {
  const copy = [...arr];
  const result = [];
  for (let i = 0; i < n && copy.length; i++) {
    const idx = Math.floor(Math.random() * copy.length);
    result.push(copy.splice(idx, 1)[0]);
  }
  return result;
}

function pickOne(arr) { return arr[Math.floor(Math.random() * arr.length)]; }

function today() {
  return new Date().toLocaleDateString('de-DE', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' });
}

function generateSession() {
  const phases = [
    { id: 'warmup',  icon: '🌅', name: 'Warm-Up',             dur: '8 Min',  exs: pick(DB.warmup,  3) },
    { id: 'main1',   icon: '🔥', name: 'Hauptteil – Latin',   dur: '15 Min', exs: pick(DB.main1,   4) },
    { id: 'main2',   icon: '💥', name: 'Hauptteil – Party',   dur: '15 Min', exs: pick(DB.main2,   4) },
    { id: 'cooldown',icon: '🌙', name: 'Cool-Down & Stretch', dur: '10 Min', exs: pick(DB.cooldown, 3) },
  ];

  const warmSong  = pickOne(MUSIC.filter(m => m.phase === 'Warm-Up'));
  const latin1    = pickOne(MUSIC.filter(m => m.phase === 'Latin'));
  const latin2    = (() => { const opts = MUSIC.filter(m => m.phase === 'Latin' && m !== latin1); return pickOne(opts); })();
  const partySong = pickOne(MUSIC.filter(m => m.phase === 'Party'));
  const coolSong  = pickOne(MUSIC.filter(m => m.phase === 'Cool-Down'));
  const tip = pickOne(TIPS);

  let html = `<div class="date-badge">📅 ${today()}</div>`;

  phases.forEach(p => {
    html += `<div class="phase">
      <div class="phase-header">
        <span class="phase-icon">${p.icon}</span>
        <span class="phase-name">${p.name}</span>
        <span class="phase-dur">${p.dur}</span>
      </div>
      <div class="ex-list">`;
    p.exs.forEach(ex => {
      html += `<div class="ex-item">
        <div class="ex-dot"></div>
        <div class="ex-text">
          <div class="ex-name">${ex.name}</div>
          <div class="ex-desc">${ex.desc}</div>
        </div>
      </div>`;
    });
    html += `</div></div>`;
  });

  const songs = [
    { label: 'Warm-Up', song: warmSong },
    { label: 'Latin 1', song: latin1 },
    { label: 'Latin 2', song: latin2 },
    { label: 'Party',   song: partySong },
    { label: 'Cool-Down', song: coolSong },
  ];

  html += `<div class="music-card">
    <div class="music-header">
      <span style="font-size:1.2rem">🎶</span>
      <div>
        <div class="music-header-title">Musikvorschläge</div>
        <div class="music-hint">Titel bei Spotify oder YouTube suchen</div>
      </div>
    </div>
    <div class="music-list">`;
  songs.forEach(s => {
    html += `<div class="music-row">
      <span class="music-phase">${s.label}</span>
      <div style="flex:1">
        <div class="music-title">${s.song.title}</div>
        <div class="music-artist">${s.song.artist}</div>
      </div>
      <span class="music-bpm">${s.song.bpm} BPM</span>
    </div>`;
  });
  html += `</div></div>`;

  html += `<div class="tip-box">
    <div class="tip-label">💡 Tipp für heute</div>
    <div class="tip-text">${tip}</div>
  </div>`;

  document.getElementById('output').innerHTML = html;
  window.scrollTo({ top: 0, behavior: 'smooth' });
}
</script>
</body>
</html>
