    { name: "Mambo-Wippschritt", desc: "Auf der Stelle wippen, abwechselnd Fersen heben. Hüfte folgt der Bewegung. Ideal als Aufwärmer." },
    { name: "Cumbia-Seitengang", desc: "Kleiner Ausfallschritt zur Seite mit Hüftschwung. Arme öffnen und schließen im Takt." },
    { name: "Schulterkreisen", desc: "Im Stand beide Schultern nach hinten kreisen, dann vorwärts. Oberkörper entspannen, tief atmen." },
    { name: "Hüftkreisen", desc: "Füße schulterbreit, Hüfte in großen Kreisen schwingen. Knie leicht gebeugt, Oberkörper ruhig." },
    { name: "March & Reach", desc: "Auf der Stelle marschieren, abwechselnd Arme nach oben strecken. Langsam warmwerden." },
    { name: "Reggaeton-Bounce", desc: "Leichtes Wippen in den Knien mit tiefem Beat, Arme locker vorne und hinten schwingen." },
    { name: "Cha-Cha-Cha Basis", desc: "Grundschritt Cha-Cha-Cha: vor – zurück – cha-cha-cha. Hüfte locker, Lächeln nicht vergessen!" },
