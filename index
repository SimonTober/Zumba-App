<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>Zumba Stunden Planer</title>
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;900&display=swap" rel="stylesheet">
<style>
  :root {
    --pink: #ff4d8d;
    --purple: #7c3aed;
    --bg: #0f0720;
    --card: #1a0f35;
    --card2: #22103f;
    --text: #f0e8ff;
    --muted: #9b85c4;
    --border: rgba(255,77,141,0.18);
  }
  * { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }
  body { font-family: 'Nunito', sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; padding-bottom: 3rem; }

  /* Header */
  .header { text-align: center; padding: 2.2rem 1rem 1.4rem; background: linear-gradient(180deg, rgba(124,58,237,0.18) 0%, transparent 100%); }
  .logo { font-size: 2.4rem; font-weight: 900; color: var(--pink); letter-spacing: 1px; line-height: 1; }
  .logo span { color: var(--text); }
  .tagline { color: var(--muted); font-size: 0.82rem; margin-top: 4px; }

  /* Main button */
  .wrap { padding: 0 1rem; max-width: 500px; margin: 0 auto; }
  .btn-generate { display: block; width: 100%; padding: 1.1rem 1rem; margin: 1.2rem 0; background: linear-gradient(135deg, var(--pink) 0%, #c8356b 100%); border: none; border-radius: 18px; font-family: 'Nunito', sans-serif; font-size: 1.15rem; font-weight: 900; color: white; cursor: pointer; letter-spacing: 0.5px; box-shadow: 0 6px 24px rgba(255,77,141,0.35); transition: transform 0.12s, box-shadow 0.12s; }
  .btn-generate:active { transform: scale(0.97); box-shadow: 0 2px 10px rgba(255,77,141,0.25); }

  /* Date badge */
  .date-badge { text-align: center; font-size: 0.78rem; color: var(--muted); margin-bottom: 0.8rem; }

  /* Phase card */
  .phase { background: var(--card); border: 1px solid var(--border); border-radius: 18px; margin-bottom: 1rem; overflow: hidden; }
  .phase-header { display: flex; align-items: center; gap: 10px; padding: 0.9rem 1rem 0.75rem; border-bottom: 1px solid var(--border); }
  .phase-icon { font-size: 1.3rem; flex-shrink: 0; }
  .phase-name { font-weight: 900; font-size: 0.95rem; color: var(--text); flex: 1; }
  .phase-dur { font-size: 0.72rem; color: var(--muted); background: rgba(255,255,255,0.06); padding: 2px 9px; border-radius: 20px; }

  /* Exercise rows */
  .ex-list { padding: 0.6rem 0.75rem 0.75rem; }
  .ex-item { display: flex; align-items: flex-start; gap: 9px; padding: 0.65rem 0.75rem; background: rgba(255,255,255,0.04); border-radius: 11px; margin-bottom: 0.45rem; }
  .ex-item:last-child { margin-bottom: 0; }
  .ex-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--pink); margin-top: 6px; flex-shrink: 0; }
  .ex-text { flex: 1; }
  .ex-name { font-weight: 700; font-size: 0.9rem; color: var(--text); }
  .ex-desc { font-size: 0.76rem; color: var(--muted); margin-top: 2px; line-height: 1.4; }

  /* Music section */
  .music-card { background: rgba(124,58,237,0.1); border: 1px solid rgba(124,58,237,0.25); border-radius: 18px; margin-bottom: 1rem; overflow: hidden; }
  .music-header { display: flex; align-items: center; gap: 8px; padding: 0.9rem 1rem 0.75rem; border-bottom: 1px solid rgba(124,58,237,0.18); }
  .music-header-title { font-weight: 900; font-size: 0.95rem; }
  .music-hint { font-size: 0.7rem; color: var(--muted); margin-top: 1px; }
  .music-list { padding: 0.6rem 0.75rem 0.75rem; }
  .music-row { display: flex; align-items: center; gap: 8px; padding: 0.6rem 0.75rem; background: rgba(255,255,255,0.04); border-radius: 11px; margin-bottom: 0.4rem; }
  .music-row:last-child { margin-bottom: 0; }
  .music-phase { font-size: 0.65rem; font-weight: 700; color: var(--pink); background: rgba(255,77,141,0.12); padding: 2px 8px; border-radius: 20px; white-space: nowrap; }
  .music-title { font-weight: 700; font-size: 0.85rem; flex: 1; }
  .music-artist { font-size: 0.72rem; color: var(--muted); }
  .music-bpm { font-size: 0.68rem; color: var(--muted); white-space: nowrap; background: rgba(255,255,255,0.06); padding: 2px 7px; border-radius: 10px; }

  /* Tip box */
  .tip-box { background: rgba(255,200,80,0.06); border: 1px solid rgba(255,200,80,0.2); border-radius: 14px; padding: 0.9rem 1rem; margin-bottom: 1rem; }
  .tip-label { font-size: 0.68rem; font-weight: 700; color: #ffca50; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 4px; }
  .tip-text { font-size: 0.83rem; color: #c9b07a; line-height: 1.55; }

  /* Empty state */
  .empty { text-align: center; padding: 3rem 1rem; color: var(--muted); }
  .empty-icon { font-size: 3.5rem; margin-bottom: 1rem; }
  .empty-title { font-weight: 700; font-size: 1.05rem; color: var(--text); margin-bottom: 0.4rem; }
  .empty-sub { font-size: 0.83rem; line-height: 1.5; }

  /* Footer */
  .footer { text-align: center; color: var(--muted); font-size: 0.72rem; padding: 1.5rem 1rem 0; }
</style>
</head>
<body>

<div class="header">
  <div class="logo">ZUMBA <span>STUNDEN</span></div>
  <div class="tagline">Für Teilnehmerinnen von 35–65 Jahren · 55 Minuten</div>
</div>

<div class="wrap">
  <button class="btn-generate" onclick="generateSession()">🎵 Neue Zumba Stunde erstellen</button>
  <div id="output">
    <div class="empty">
      <div class="empty-icon">💃</div>
      <div class="empty-title">Bereit zum Tanzen!</div>
      <div class="empty-sub">Tippe auf den Button und erhalte deine persönliche Zumba-Stunde für heute.</div>
    </div>
  </div>
  <div class="footer">Zumba Stunden Planer · Jeden Tag neu generiert</div>
</div>

<script>
