    { name: "Merengue-March", desc: "Knie hochziehen im Merengue-Takt, Arme kraftvoll pumpen. Tempo steigern nach 8 Wiederholungen." },
    { name: "Salsa mit Arm-Styling", desc: "Grundschritt Salsa, dazu fließende Armbewegungen von innen nach außen. Körpergefühl entwickeln." },
    { name: "Samba-Bounce", desc: "Samba-typisches Kniebeugen im schnellen Rhythmus, Oberkörper dreht leicht mit. Hüfte aktiv einsetzen." },
    { name: "Cha-Cha-Variation", desc: "Cha-Cha-Cha mit Seitausfallschritt und Klatschen auf Beat 1. Zügiges Tempo, kontrollierte Schritte." },
    { name: "Flamenco Stomps", desc: "Kraftvolles Aufstampfen, Arme über Kopf, Hüften seitlich. Kurze Pause, dann Wiederholung." },
    { name: "Reggaeton Steps", desc: "Tiefer Stand, Füße wechseln vorne, Arm-Pumps dazu. Hip-Hop-Einfluss, kraftvoll und taktfest." },
